# Local Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# Environment
ENVIRONMENT=dev

# AWS S3 (Must exist - usually created via 'sam deploy')
S3_BUCKET=your-s3-bucket-name

# Discord
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_PUBLIC_KEY=your-discord-public-key
DISCORD_CLASSIFICATIONS_CHANNEL_ID=your-classifications-channel-id
DISCORD_SETTLEMENTS_CHANNEL_ID=your-settlements-channel-id

# Plaid
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ACCESS_TOKEN=your-plaid-access-token
PLAID_ENV=sandbox

# Users
USER_A_NAME=Alex
USER_B_NAME=Beth